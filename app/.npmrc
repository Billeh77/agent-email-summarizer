# GitHub Packages registry for @arata-ai scope
# Requires GITHUB_TOKEN with `read:packages` scope.
#
# Setup (one-time):
#   1. gh auth login
#   2. gh auth refresh -s read:packages
#   3. Add to ~/.zshrc:  export GITHUB_TOKEN=$(gh auth token 2>/dev/null)
#   4. source ~/.zshrc
@arata-ai:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
